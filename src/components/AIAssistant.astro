---
/**
 * Buildsite AI assistant widget.
 *
 * Floating launch button (bottom-right, 🏗 crane). Click opens a chat
 * panel that POSTs to /api/chat (handled by src/worker.ts). Messages
 * persist in sessionStorage so a refresh doesn't lose the thread.
 *
 * Design notes:
 * - Inherits the dark/light tokens from global.css.
 * - Animations move transform only (no opacity) per design-system rule.
 * - The 🏗 launch glyph is a documented override of the "no emoji" rule.
 */
---

<button
  id="ai-assistant-launch"
  type="button"
  aria-label="Open the Buildsite assistant"
  aria-controls="ai-assistant-panel"
  aria-expanded="false"
>
  <span class="ai-launch-glyph" aria-hidden="true">🏗</span>
  <span class="ai-launch-pulse" aria-hidden="true"></span>
</button>

<div
  id="ai-assistant-panel"
  role="dialog"
  aria-labelledby="ai-assistant-title"
  aria-modal="false"
  hidden
>
  <header>
    <div>
      <p id="ai-assistant-title">Hi, I'm Buildsite<span style="color: var(--color-accent);">.</span></p>
      <p class="ai-sub">Ask about pricing, the AI assistant, or how it works.</p>
    </div>
    <button
      type="button"
      id="ai-assistant-close"
      aria-label="Close the assistant"
      class="mono"
    >×</button>
  </header>

  <div id="ai-assistant-messages" role="log" aria-live="polite" aria-atomic="false">
    <div class="ai-msg ai-msg-assistant">
      <p>I'm the Buildsite assistant. I can explain tiers, what's included, and whether we'd be a fit. What's on your mind?</p>
    </div>
  </div>

  <form id="ai-assistant-form" autocomplete="off">
    <label for="ai-assistant-input" class="visually-hidden">Your message</label>
    <textarea
      id="ai-assistant-input"
      name="message"
      placeholder="Ask anything about Buildsite…"
      rows="1"
      maxlength="2000"
      required
    ></textarea>
    <button type="submit" id="ai-assistant-send" aria-label="Send message" class="mono">↑</button>
  </form>

  <p class="ai-foot mono">Replies are AI. For anything binding, book a call.</p>
</div>

<style>
  /* ────────────────────────────────────────────────────────────
     LAUNCH BUTTON
     56px circle, bottom-right, accent ring + breathing pulse.
     ──────────────────────────────────────────────────────────── */
  #ai-assistant-launch {
    position: fixed;
    right: 24px;
    bottom: 24px;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    cursor: pointer;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 180ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 180ms ease,
      border-color 180ms ease;
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.6);
  }

  #ai-assistant-launch:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 0 32px -8px var(--color-accent);
  }

  #ai-assistant-launch:active {
    transform: translateY(0);
  }

  .ai-launch-glyph {
    font-size: 28px;
    line-height: 1;
    display: block;
  }

  .ai-launch-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 2px solid var(--color-accent);
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ai-launch-pulse {
      animation: ai-pulse 2.6s ease-out infinite;
    }
  }

  @keyframes ai-pulse {
    0% { transform: scale(0.92); opacity: 0; }
    35% { opacity: 0.35; }
    100% { transform: scale(1.45); opacity: 0; }
  }

  /* ────────────────────────────────────────────────────────────
     PANEL
     ──────────────────────────────────────────────────────────── */
  #ai-assistant-panel {
    position: fixed;
    right: 24px;
    bottom: 96px;
    width: min(380px, calc(100vw - 32px));
    height: min(560px, calc(100vh - 132px));
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.7);
    display: flex;
    flex-direction: column;
    z-index: 60;
    overflow: hidden;
    transform: translateY(12px);
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  #ai-assistant-panel[hidden] {
    display: none;
  }
  #ai-assistant-panel.is-open {
    transform: translateY(0);
  }

  #ai-assistant-panel header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }
  #ai-assistant-panel header p {
    margin: 0;
  }
  #ai-assistant-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-fg);
    letter-spacing: -0.015em;
  }
  .ai-sub {
    font-size: 12px;
    color: var(--color-fg-muted);
    margin-top: 4px !important;
  }

  #ai-assistant-close {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    width: 28px;
    height: 28px;
    border-radius: 0.5rem;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
  }
  #ai-assistant-close:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-muted);
  }

  /* ────────────────────────────────────────────────────────────
     MESSAGES
     ──────────────────────────────────────────────────────────── */
  #ai-assistant-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ai-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 0.875rem;
    font-size: 14px;
    line-height: 1.5;
  }
  .ai-msg p {
    margin: 0;
    color: inherit;
  }
  .ai-msg p + p {
    margin-top: 8px;
  }
  .ai-msg-assistant {
    background: var(--color-surface-2);
    color: var(--color-fg);
    border-bottom-left-radius: 0.25rem;
    align-self: flex-start;
  }
  .ai-msg-user {
    background: var(--color-accent);
    color: var(--color-fg-on-accent);
    border-bottom-right-radius: 0.25rem;
    align-self: flex-end;
  }
  .ai-msg-error {
    background: var(--color-danger-soft);
    color: var(--color-fg);
    border: 1px solid var(--color-danger);
    border-bottom-left-radius: 0.25rem;
    align-self: flex-start;
  }
  .ai-msg-typing {
    background: var(--color-surface-2);
    color: var(--color-fg-muted);
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 8px 14px;
  }

  /* ────────────────────────────────────────────────────────────
     FORM
     ──────────────────────────────────────────────────────────── */
  #ai-assistant-form {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  #ai-assistant-input {
    flex: 1;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    padding: 10px 12px;
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.4;
    resize: none;
    max-height: 120px;
    transition: border-color 160ms ease;
  }
  #ai-assistant-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  #ai-assistant-input::placeholder {
    color: var(--color-fg-dim);
  }
  #ai-assistant-input:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  #ai-assistant-send {
    background: var(--color-accent);
    color: var(--color-fg-on-accent);
    border: 1px solid var(--color-accent);
    width: 36px;
    height: 36px;
    border-radius: 0.625rem;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 160ms ease, transform 160ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  #ai-assistant-send:hover:not(:disabled) {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }
  #ai-assistant-send:active {
    background: var(--color-accent-press);
    transform: translateY(0);
  }
  #ai-assistant-send:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ai-foot {
    font-size: 10px;
    color: var(--color-fg-dim);
    text-align: center;
    padding: 0 16px 12px;
    margin: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* Hide entirely on print. */
  @media print {
    #ai-assistant-launch,
    #ai-assistant-panel { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    var launch = document.getElementById("ai-assistant-launch");
    var panel = document.getElementById("ai-assistant-panel");
    var closeBtn = document.getElementById("ai-assistant-close");
    var form = document.getElementById("ai-assistant-form");
    var input = document.getElementById("ai-assistant-input");
    var sendBtn = document.getElementById("ai-assistant-send");
    var messages = document.getElementById("ai-assistant-messages");

    if (!launch || !panel || !form || !input || !messages) return;

    var STORAGE_KEY = "buildsite-chat-thread";

    function openPanel() {
      panel.hidden = false;
      // Defer the class toggle so the transition runs from translateY(12px) -> 0.
      requestAnimationFrame(function () {
        panel.classList.add("is-open");
      });
      launch.setAttribute("aria-expanded", "true");
      setTimeout(function () { input.focus(); }, 200);
    }

    function closePanel() {
      panel.classList.remove("is-open");
      launch.setAttribute("aria-expanded", "false");
      setTimeout(function () { panel.hidden = true; }, 240);
    }

    launch.addEventListener("click", function () {
      if (panel.hidden) openPanel();
      else closePanel();
    });
    if (closeBtn) closeBtn.addEventListener("click", closePanel);

    // Close on Escape when panel focused.
    panel.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closePanel();
    });

    // Auto-resize the textarea.
    input.addEventListener("input", function () {
      input.style.height = "auto";
      input.style.height = Math.min(input.scrollHeight, 120) + "px";
    });

    // Submit on Enter (Shift+Enter for newline).
    input.addEventListener("keydown", function (e) {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    function appendMessage(role, content) {
      var el = document.createElement("div");
      el.className = "ai-msg ai-msg-" + role;
      // role can be "user", "assistant", or "error"
      var p = document.createElement("p");
      p.textContent = content;
      el.appendChild(p);
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
      return el;
    }

    function appendTyping() {
      var el = document.createElement("div");
      el.className = "ai-msg ai-msg-typing";
      el.textContent = "thinking…";
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
      return el;
    }

    // Conversation state — array of {role, content}. Excludes the seed greeting.
    var thread = [];

    // Hydrate from sessionStorage on load.
    try {
      var stored = sessionStorage.getItem(STORAGE_KEY);
      if (stored) {
        thread = JSON.parse(stored);
        if (Array.isArray(thread)) {
          thread.forEach(function (m) {
            if (m && (m.role === "user" || m.role === "assistant") && typeof m.content === "string") {
              appendMessage(m.role, m.content);
            }
          });
        } else {
          thread = [];
        }
      }
    } catch (_) {
      thread = [];
    }

    function persist() {
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(thread)); } catch (_) {}
    }

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      var text = input.value.trim();
      if (!text) return;

      // Optimistic user message.
      appendMessage("user", text);
      thread.push({ role: "user", content: text });
      persist();

      input.value = "";
      input.style.height = "auto";
      input.disabled = true;
      sendBtn.disabled = true;

      var typingEl = appendTyping();

      try {
        var res = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: thread }),
        });

        typingEl.remove();

        if (!res.ok) {
          var errBody = await res.json().catch(function () { return {}; });
          appendMessage("error", errBody.error || "Something broke. Please try again or email hello@buildsite.dev.");
        } else {
          var data = await res.json();
          var content = (data && data.content) || "";
          if (!content) {
            appendMessage("error", "I drew a blank. Try rephrasing.");
          } else {
            appendMessage("assistant", content);
            thread.push({ role: "assistant", content: content });
            persist();
          }
        }
      } catch (err) {
        if (typingEl.parentNode) typingEl.remove();
        appendMessage("error", "Couldn't reach the assistant. Try again, or email hello@buildsite.dev.");
      } finally {
        input.disabled = false;
        sendBtn.disabled = false;
        input.focus();
      }
    });
  })();
</script>
